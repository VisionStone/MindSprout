{
  "name": "mindsprout",
  "version": "0.1.0",
  "description": "AI-powered mind mapping desktop app",
  "main": "dist/main.cjs",
  "type": "module",
  "scripts": {
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "vite build --config vite.main.config.ts",
    "build:preload": "vite build --config vite.preload.config.ts",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:preload\" \"npm run dev:renderer\"",
    "dev:main": "vite build --config vite.main.config.ts --mode development --watch",
    "dev:preload": "vite build --config vite.preload.config.ts --mode development --watch",
    "dev:renderer": "vite --config vite.renderer.config.ts",
    "start": "electron .",
    "test": "vitest",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "build": {
    "appId": "com.visionstone.mindsprout",
    "productName": "MindSprout",
    "directories": {
      "output": "release",
      "buildResources": "buildResources"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "buildResources/splash.html",
        "to": "splash.html"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "buildResources/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "dmg": {
      "sign": false
    }
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.7",
    "@llumiverse/core": "^1.3.0",
    "@llumiverse/drivers": "^1.3.0",
    "better-sqlite3": "^12.0.0",
    "d3-force": "^3.0.0",
    "dagre": "^0.8.5",
    "electron-log": "^5.3.4",
    "mammoth": "^1.12.0",
    "marked": "^18.0.4",
    "pdf-parse": "^2.4.5",
    "solid-js": "^1.9.5"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.54",
    "@types/marked": "^5.0.2",
    "@types/node": "^22.15.18",
    "concurrently": "^9.1.2",
    "electron": "^36.2.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.8.3",
    "vite": "^6.1.6",
    "vite-plugin-solid": "^2.11.6",
    "vitest": "^3.2.3"
  }
}
